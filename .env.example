# ===========================================
# CARD PRICER — Environment Configuration
# ===========================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# --- Required ---
# Anthropic API key for Claude Vision (card identification)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- eBay API (for sold listings comparison) ---
# Register at: https://developer.ebay.com/
# Create an app → get production App ID + Cert ID
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id

# --- Cardmarket ---
# No key needed! Uses live scraping of actual Cardmarket listings
# filtered by English language + matching condition.

# --- Settings ---
PORT=3000
DEFAULT_BUY_PERCENTAGE=60
